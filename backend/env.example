## Server
PORT=3000
NODE_ENV=development
APP_VERSION=1.0.0

## Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=authify

## JWT
JWT_SECRET=change-me-in-production

## Email / SMTP
EMAIL_FROM=noreply@authify.com
EMAIL_FROM_NAME=Authify
FRONTEND_URL=http://localhost:5173
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password


